loki:
  enabled: true
  image:
    repository: grafana/loki
    tag: "2.9.3"
    pullPolicy: IfNotPresent

  # --- 특정 노드 고정 설정 제거됨 ---

  # --- 자원 제한 (2GB 서버 최적화) ---
  resources:
    limits:
      memory: "512Mi"
    requests:
      memory: "256Mi"

  config:
    limits_config:
      max_query_parallelism: 2
    querier:
      max_concurrent: 2

  persistence:
    enabled: false

  service:
    type: NodePort
    nodePort: 32000

promtail:
  enabled: true
  # --- 로그 수집 최적화: lunch 네임스페이스만 수집 ---
  pipelineStages:
    - docker: {}
    - match:
        selector: '{namespace!="lunch"}'
        action: drop

  resources:
    limits:
      memory: "150Mi"
    requests:
      memory: "64Mi"

