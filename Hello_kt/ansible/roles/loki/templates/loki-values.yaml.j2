loki:
  enabled: true
  image:
    repository: grafana/loki
    tag: "2.9.3"
    pullPolicy: IfNotPresent

  # --- 자가 복구(Self-healing) 설정 추가 ---
  livenessProbe:
    httpGet:
      path: /ready
      port: 3100
    initialDelaySeconds: 45
    periodSeconds: 10
  readinessProbe:
    httpGet:
      path: /ready
      port: 3100
    initialDelaySeconds: 45
    periodSeconds: 10
  # -------------------------------------

  # --- 성능 최적화 및 오류 수정 반영 ---
  config:
    limits_config:
      max_query_parallelism: 24
      query_timeout: 5m
      max_query_series: 100000
    
    querier:
      max_concurrent: 16

    query_range:
      parallelise_shardable_queries: true
  # ----------------------------------

  persistence:
    enabled: false

  service:
    type: NodePort
    nodePort: 32000

promtail:
  enabled: true
